# Jocril LOJA-ONLINE — env vars
# Copy to .env.local and fill in. .env.local is gitignored.

# ---------- Supabase (B0) ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Clerk (B2) ----------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/registar
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/conta
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/conta
ADMIN_EMAILS=

# ---------- Eupago payments (B4) ----------
EUPAGO_API_KEY=
EUPAGO_BASE_URL=https://sandbox.eupago.pt

# ---------- Resend emails (B7) ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---------- Site ----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
