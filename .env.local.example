# Jocril LOJA-ONLINE — env vars
# Copy to .env.local and fill in. .env.local is gitignored.

# ---------- Supabase (B0) ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Clerk (B2) ----------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/entrar
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/registar
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/conta
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/conta

# ---------- Admin access ----------
# ADMIN_EMAILS: server-side allow-list (comma-separated). ADMIN_EMAIL is the
# single-value fallback used by the email notifier when ADMIN_EMAILS is unset.
# NEXT_PUBLIC_ADMIN_EMAILS: client-side copy used by the store header to reveal
# the admin link. Keep it in sync with ADMIN_EMAILS.
ADMIN_EMAILS=
ADMIN_EMAIL=
NEXT_PUBLIC_ADMIN_EMAILS=

# ---------- Eupago payments (B4) ----------
EUPAGO_API_KEY=
EUPAGO_BASE_URL=https://sandbox.eupago.pt

# ---------- Resend emails (B7) ----------
RESEND_API_KEY=
EMAIL_FROM=

# ---------- Site ----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
